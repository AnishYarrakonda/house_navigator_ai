# Waypoint environment — copy to .env and fill in. See prompts/README.md.

# "mock" runs the whole app with the in-memory data layer (no backend needed).
# Flip to "live" once Lane 4 + Supabase are ready.
VITE_DATA_MODE=mock

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side ONLY. NEVER prefix with VITE_ (that would leak it to the browser).
ANTHROPIC_API_KEY=sk-ant-...
