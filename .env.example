# Waypoint environment — copy to .env and fill in.
#
# The app runs entirely on the in-memory data layer (seeded + live DataSF
# augmentation) — no backend or database needed.

# Server-side ONLY. NEVER prefix with VITE_ (that would leak it to the browser).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the agents' model. Defaults to Haiku (cheap testing).
# WAYPOINT_MODEL=claude-opus-4-8

# Server-side ONLY. OpenRouteService key — powers road-snapped routes
# (api/route.ts) and listing address geocoding (api/listing.ts). Free: sign up
# at https://openrouteservice.org/dev/#/signup (2000 req/day). If omitted, the
# map falls back to a clean curved line and listings geocode near SF center.
# `npm run dev` reads this too: a dev Vite plugin (vite-plugins/api-dev.ts) runs
# the api/* handlers locally, so set it here to get real street routes in dev.
ORS_API_KEY=

# DataSF / Socrata app token. Optional — requests work without it but are
# rate-limited. Register free at https://data.sfgov.org/profile/app_tokens
DATASF_APP_TOKEN=
