# Waypoint environment — copy to .env and fill in. See prompts/README.md.

# "mock" runs the whole app with the in-memory data layer (no backend needed).
# Flip to "live" once Lane 4 + Supabase are ready.
VITE_DATA_MODE=mock

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-side ONLY. NEVER prefix with VITE_ (that would leak it to the browser).
ANTHROPIC_API_KEY=sk-ant-...

# Server-side ONLY — the four runtime agents (api/*) read/write the blackboard
# with the service-role key. Get it from Supabase → Settings → API → service_role.
# (If omitted, agents fall back to the anon key, which works only because RLS is
# off for the demo.) SUPABASE_URL mirrors VITE_SUPABASE_URL.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: override the agents' model. Defaults to Haiku (cheap testing).
# WAYPOINT_MODEL=claude-opus-4-8

# Server-side ONLY. OpenRouteService key — powers road-snapped routes
# (api/route.ts) and listing address geocoding (api/listing.ts). Free: sign up
# at https://openrouteservice.org/dev/#/signup (2000 req/day). If omitted, the
# map falls back to a clean curved line and listings geocode near SF center.
ORS_API_KEY=

# DataSF / Socrata app token. Optional — requests work without it but are
# rate-limited. Register free at https://data.sfgov.org/profile/app_tokens
DATASF_APP_TOKEN=
